# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=travel
POSTGRES_PASSWORD=travelpass
POSTGRES_DB=traveldb

# ─── Backend ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://travel:travelpass@postgres:5432/traveldb
SECRET_KEY=CHANGE_ME_to_a_very_long_random_secret_key_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── AI / LLM ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Web Search ───────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ─── Weather ──────────────────────────────────────────────
WEATHERAPI_KEY=

# ─── Frontend ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ─── Email (SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=vudunghs@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM_NAME=TravelAI Assistant

# ─── Travelport ───────────────────────────────────────────
TRAVELPORT_USERNAME=your_username
TRAVELPORT_PASSWORD=your_password
TRAVELPORT_CLIENT_ID=your_client_id
TRAVELPORT_CLIENT_SECRET=your_client_secret
TRAVELPORT_PCC=your_pcc
TRAVELPORT_ACCESS_GROUP=your_access_group
TRAVELPORT_CURRENCY=HKD
TRAVELPORT_SANDBOX=true
TRAVELPORT_AUTH_URL=https://auth.pp.travelport.net/oauth/token
TRAVELPORT_API_BASE_URL=https://api.pp.travelport.net
